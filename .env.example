# === Required ===
HYPERLIQUID_PRIVATE_KEY=0x_your_agent_private_key  # Agent/API wallet private key (signer only)
HYPERLIQUID_VAULT_ADDRESS=0x_your_main_wallet      # Main wallet address that holds funds (agent trades on its behalf)

# === Trading config ===
ASSETS="BTC ETH SOL OIL GOLD SILVER SPX"
INTERVAL="5m"

# === AI provider (one active provider at a time) ===
AI_PROVIDER=anthropic                              # anthropic | openai | gemini
AI_MODEL="claude-sonnet-4-20250514"              # Model for selected provider
ENABLE_AI_TRADING=true                             # Enable AI strategy
AI_CAPITAL_PCT=100                                 # % of account capital allocated to AI decisions

# === Algo mode ===
ENABLE_ALGO_TRADING=false                          # Enable deterministic algo strategy
ALGO_CAPITAL_PCT=0                                 # % of account capital allocated to algo decisions
ALGO_FILE_PATH=algo.py                             # Custom strategy file path (must define generate_trade_decisions)

# Enabled percentages must each be 0-100 and their enabled total must not exceed 100

# === Provider API keys (set at least the selected provider key) ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here      # From https://console.anthropic.com
OPENAI_API_KEY=your_openai_api_key_here            # From https://platform.openai.com
GEMINI_API_KEY=your_gemini_api_key_here            # From https://aistudio.google.com

# === Risk management (all have sensible defaults) ===
MAX_POSITION_PCT=20                # Max single position as % of portfolio (default: 20)
MAX_LOSS_PER_POSITION_PCT=20       # Force-close at this % loss (default: 20)
MAX_LEVERAGE=10                    # Hard leverage cap (default: 10)
MAX_TOTAL_EXPOSURE_PCT=80          # Max total notional as % of portfolio (default: 80)
DAILY_LOSS_CIRCUIT_BREAKER_PCT=25  # Stop new trades at this daily drawdown % (default: 25)
MANDATORY_SL_PCT=5                 # Auto SL distance % if AI doesn't set one (default: 5)
MAX_CONCURRENT_POSITIONS=10        # Max simultaneous positions (default: 10)
MIN_BALANCE_RESERVE_PCT=10         # Don't trade below this % of initial balance (default: 10)
MIN_TRADE_CONFIDENCE=0.55          # Block buy/sell decisions below this confidence when provided

# === Optional ===
HYPERLIQUID_NETWORK=mainnet        # mainnet or testnet
# OPENAI_BASE_URL=https://api.openai.com/v1
# MAX_TOKENS=4096                  # Max output tokens for selected AI provider
# AI_SANITIZE_MODEL=claude-haiku-4-5-20251001  # Optional cleanup model for malformed output
# THINKING_ENABLED=false           # Anthropic-only extended thinking
# THINKING_BUDGET_TOKENS=10000     # Anthropic-only token budget for thinking
# ENABLE_TOOL_CALLING=false        # Tool-calling currently available for Anthropic mode
# API_HOST=0.0.0.0
# API_PORT=3000

# === Legacy key compatibility (still supported) ===
# LLM_MODEL, ENABLE_CLAUDE_TRADING, CLAUDE_CAPITAL_PCT, SANITIZE_MODEL
