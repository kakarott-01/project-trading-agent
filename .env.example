# Environment Profiles Template
#
# Keep variables split into separate files:
# - .env.common      (shared settings)
# - .env.anthropic   (Anthropic profile)
# - .env.openai      (OpenAI profile)
# - .env.gemini      (Gemini profile)
#
# Build runtime .env with:
#   cat .env.common .env.openai > .env
# or
#   cat .env.common .env.anthropic > .env
# or
#   cat .env.common .env.gemini > .env


# ========================
# .env.common
# ========================

# Hyperliquid (required)
HYPERLIQUID_PRIVATE_KEY=0x_your_agent_private_key
HYPERLIQUID_VAULT_ADDRESS=0x_your_main_wallet
HYPERLIQUID_NETWORK=mainnet

# Hyperliquid (optional/legacy)
# LIGHTER_PRIVATE_KEY=0x_optional_legacy_key
# MNEMONIC=optional_mnemonic_if_used
# HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz

# Runtime controls
ASSETS="BTC ETH SOL OIL GOLD SILVER SPX"
INTERVAL="5m"

# Execution modes
ENABLE_AI_TRADING=true
AI_CAPITAL_PCT=100
ENABLE_ALGO_TRADING=false
ALGO_CAPITAL_PCT=0
ALGO_FILE_PATH=algo.py

# Risk management
MAX_POSITION_PCT=20
MAX_LOSS_PER_POSITION_PCT=20
MAX_LEVERAGE=10
MAX_TOTAL_EXPOSURE_PCT=80
DAILY_LOSS_CIRCUIT_BREAKER_PCT=25
MANDATORY_SL_PCT=5
MAX_CONCURRENT_POSITIONS=10
MIN_BALANCE_RESERVE_PCT=10
MIN_TRADE_CONFIDENCE=0.55

# LLM runtime options
MAX_TOKENS=4096
ENABLE_TOOL_CALLING=false

# API server
API_HOST=0.0.0.0
API_PORT=3000

# Optional/legacy extras
# APP_PORT=3000
# TAAPI_API_KEY=optional_taapi_key
# OPENROUTER_API_KEY=optional_openrouter_key


# ========================
# .env.anthropic
# ========================

AI_PROVIDER=anthropic
AI_MODEL="claude-sonnet-4-20250514"
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_SANITIZE_MODEL=claude-haiku-4-5-20251001

# Anthropic-specific optional controls
THINKING_ENABLED=false
THINKING_BUDGET_TOKENS=10000


# ========================
# .env.openai
# ========================

AI_PROVIDER=openai
AI_MODEL=gpt-4.1
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_SANITIZE_MODEL=gpt-4.1-mini


# ========================
# .env.gemini
# ========================

AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-pro
GEMINI_API_KEY=your_gemini_api_key_here
AI_SANITIZE_MODEL=gemini-2.5-flash


# ========================
# Legacy aliases (still supported)
# ========================

# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ENABLE_CLAUDE_TRADING=true
# CLAUDE_CAPITAL_PCT=100
# SANITIZE_MODEL=claude-haiku-4-5-20251001
