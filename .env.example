# Environment Profiles Template
# See setup.md for full instructions.

# ========================
# .env.common
# ========================

# Hyperliquid (required)
HYPERLIQUID_PRIVATE_KEY=0x_your_agent_private_key
HYPERLIQUID_VAULT_ADDRESS=0x_your_main_wallet
HYPERLIQUID_NETWORK=mainnet

# Runtime controls
ASSETS="BTC ETH SOL OIL GOLD SILVER SPX"
INTERVAL="5m"

# Execution modes
ENABLE_AI_TRADING=true
AI_CAPITAL_PCT=100
ENABLE_ALGO_TRADING=false
ALGO_CAPITAL_PCT=0
ALGO_FILE_PATH=algo.py

# Risk management
MAX_POSITION_PCT=20
MAX_LOSS_PER_POSITION_PCT=20
MAX_LEVERAGE=10
MAX_TOTAL_EXPOSURE_PCT=80
DAILY_LOSS_CIRCUIT_BREAKER_PCT=25
MANDATORY_SL_PCT=5
MAX_CONCURRENT_POSITIONS=10
MIN_BALANCE_RESERVE_PCT=10
MIN_TRADE_CONFIDENCE=0.55

# LLM runtime options
MAX_TOKENS=4096
ENABLE_TOOL_CALLING=false

# API server
# SECURITY: Default is 127.0.0.1 (loopback only).
# Only set to 0.0.0.0 if behind a reverse proxy with auth at the network layer.
API_HOST=127.0.0.1
API_PORT=3000

# API authentication — REQUIRED before exposing this service on a network.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable auth (dev/local only).
API_SECRET=

# ========================
# .env.anthropic
# ========================

AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_SANITIZE_MODEL=claude-haiku-4-5-20251001

# Anthropic-specific optional controls
THINKING_ENABLED=false
THINKING_BUDGET_TOKENS=10000


# ========================
# .env.openai
# ========================

AI_PROVIDER=openai
AI_MODEL=gpt-4.1
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_SANITIZE_MODEL=gpt-4.1-mini


# ========================
# .env.gemini
# ========================

AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-pro
GEMINI_API_KEY=your_gemini_api_key_here
AI_SANITIZE_MODEL=gemini-2.5-flash


# ========================
# Legacy aliases (still supported)
# ========================

# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ENABLE_CLAUDE_TRADING=true
# CLAUDE_CAPITAL_PCT=100
# SANITIZE_MODEL=claude-haiku-4-5-20251001